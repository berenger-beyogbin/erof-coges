# SUPABASE_URL: URL of your Supabase project (e.g., https://xxxxxxxxxxxxxx.supabase.co)
VITE_SUPABASE_URL=""

# SUPABASE_ANON_KEY: Anonymous public key for Supabase Client SDK
VITE_SUPABASE_ANON_KEY=""

# Deployment only: Supabase personal access token.
# Create one from Supabase Dashboard > Account > Access Tokens.
SUPABASE_ACCESS_TOKEN=""

# Deployment only: database password for the linked Supabase project.
SUPABASE_DB_PASSWORD=""

# Deployment only: service-role key used by Edge Functions server-side.
# Never expose this key in frontend code.
SUPABASE_SERVICE_ROLE_KEY=""
